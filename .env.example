# ─────────────────────────────────────────────────────────────
# Nepali AI Caption App — environment template
# Copy to .env (root), web/.env.local, worker/.env as needed.
# Leave blank to run in STUB mode (services return mock data).
# ─────────────────────────────────────────────────────────────

# Groq Whisper — STT engine (Phase 1).
# Get key: https://console.groq.com/keys  (free tier)
GROQ_API_KEY=

# Supabase — Postgres + Auth + Storage + pgvector.
# Create project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Worker location — Next.js calls this for transcribe/export.
# Local FastAPI default below.
WORKER_URL=http://localhost:8000

# SSRF guard — comma-separated hostnames the worker may fetch video from.
# Set to your Supabase Storage host in prod, e.g. "<project>.supabase.co".
# Empty in dev = stub mode (no real fetch). See worker/app/security.py.
ALLOWED_SOURCE_HOSTS=

# ── Optional / later phases (leave blank for MVP) ──
# Cloudflare R2 (swap from Supabase Storage at egress scale)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Anthropic Claude — video chatbot RAG (Phase 3)
ANTHROPIC_API_KEY=

# Gladia — alternative STT (blueprint Ninglish fallback). Free 10 hrs/mo.
# Get key: https://app.gladia.io  · set STT_PROVIDER=gladia to use it.
GLADIA_API_KEY=
STT_PROVIDER=groq
